# Anchor Seed Stack — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or just run ./setup.sh and it will do this for you.

# Your timezone (used by Pi-hole for log timestamps)
# Find yours: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Chicago

# Pi-hole admin panel password
# This is for the Pi-hole web UI at http://YOUR_IP/admin
PIHOLE_PASSWORD=

# Vaultwarden admin token
# Used to access the Vaultwarden admin panel at http://YOUR_IP:8080/admin
# Generate one: openssl rand -hex 32
VAULTWARDEN_ADMIN_TOKEN=

# Set to "false" after you create your first Vaultwarden account
# This prevents anyone else on your network from signing up
SIGNUPS_ALLOWED=true
