# Anchor Proposal Generator — Configuration
# Copy to .env and edit as needed.

# Server
HOST=127.0.0.1
PORT=5000
SECRET_KEY=change-this-to-a-random-string
FLASK_DEBUG=0

# Database
DB_PATH=sessions.db

# Email notification (optional — leave SMTP_HOST blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
NOTIFY_EMAIL=
